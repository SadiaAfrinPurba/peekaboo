{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": [
        "run",
        "-d",
        "web-server",
        "--web-renderer",
        "html",
        "--web-hostname",
        "127.0.0.1",
        "--web-port",
        "8080"
      ],
      "port": 8080
    }
  ]
}
